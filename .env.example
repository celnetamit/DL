# ──────────────────────────────────────────────
#  Aether LMS – Environment Variables Template
#  Copy this to .env and fill in real values.
# ──────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=8080
# Set to "release" in production to suppress Gin debug logs
GIN_MODE=release

# ── Database ─────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/lms_db?sslmode=disable

# Postgres credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=aether_lms

# ── JWT ──────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_string

# ── Admin Seed ───────────────────────────────
# Overrides the default seeded super_admin account on first boot
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_me_in_production

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
# Webhook URL: https://api.journalslibrary.com/api/v1/subscriptions/webhook

# ── AI Engine ────────────────────────────────
# URL of the Python AI Engine service
AI_ENGINE_URL=http://localhost:8000
# Anthropic API key (used by ai-engine-py service)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
# Production example: https://journalslibrary.com,https://www.journalslibrary.com
APP_BASE_URL=https://journalslibrary.com

# ── Google OAuth ─────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised Redirect URI (prod): https://api.journalslibrary.com/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=https://api.journalslibrary.com/api/v1/auth/google/callback
