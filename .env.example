# ──────────────────────────────────────────────
#  Aether LMS – Environment Variables Template
#  Copy this to .env and fill in real values.
# ──────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=8080
APP_BASE_URL=http://localhost:3000

# ── Database ─────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/lms_db?sslmode=disable

# ── JWT ──────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=GUaQjHnlcACv+HEp3Cgo9hg1eqrZkj2tD24Teb49BbJ0PVSQw5d2Bt/sndWmP+H7

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_SSg2uz4zfyBYkn
RAZORPAY_KEY_SECRET=6AyAarSM4plW0KgXBM3MttVA
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
#https://your-domain.com/api/v1/subscriptions/webhook

# ── AI Engine ────────────────────────────────
# URL of the Python AI Engine service
AI_ENGINE_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins (supports wildcard * for dev)
# Examples:
#   ALLOWED_ORIGINS=*
#   ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000
