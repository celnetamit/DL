# ──────────────────────────────────────────────
#  Aether LMS – Environment Variables Template
#  Copy this to .env and fill in real values.
# ──────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=8080
APP_ENV=production
# Set to "release" in production to suppress Gin debug logs
GIN_MODE=release
TRUSTED_PROXIES=127.0.0.1,::1

# ── Database ─────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/lms_db?sslmode=disable

# Postgres credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=aether_lms
# Apply embedded SQL migrations on backend boot. Set to false only for advanced/manual workflows.
RUN_MIGRATIONS=true
# Set to true once when adopting migrations on an already-existing database schema.
BASELINE_EXISTING_SCHEMA=false

# ── JWT ──────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_string

# ── Admin Seed ───────────────────────────────
# Overrides the default seeded super_admin account on first boot
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_me_in_production

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
LEAD_WEBHOOK_URL=https://crm.example.com/webhooks/leads
LEAD_WEBHOOK_SECRET=your_crm_webhook_secret
# Webhook URL: https://api.journalslibrary.com/api/v1/subscriptions/webhook

# ── AI Engine ────────────────────────────────
# URL of the Python AI Engine service
AI_ENGINE_URL=http://localhost:8000
# Gemini API key (used by ai-engine-py service)
GEMINI_API_KEY=AIzaSyAtwDZdrM2wDQJ8U418X9Mj_aWBI68Xjlk
# Example: gemini-1.5-flash or a newer production-approved Gemini model
GEMINI_MODEL=gemini-1.5-flash

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
# Production example: https://journalslibrary.com,https://www.journalslibrary.com
APP_BASE_URL=https://journalslibrary.com
NEXT_PUBLIC_API_URL=https://api.journalslibrary.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx

# ── Google OAuth ─────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised Redirect URI (prod): https://api.journalslibrary.com/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=https://api.journalslibrary.com/api/v1/auth/google/callback
